# Documents Service — local .env (host-process debugging)
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_REQUEST_BODY=true
SERVICE_PORT=8002

# PostgreSQL
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DOCUMENTS_DB_NAME=documents_db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Redis / Taskiq
TASKIQ_BROKER_URL=redis://localhost:6379/0

# OSS (leave blank for local dev — upload endpoints will error gracefully)
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
