# Application Service — local .env (host-process debugging)
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_REQUEST_BODY=true
SERVICE_PORT=8001

# PostgreSQL
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
APPLICATION_DB_NAME=application_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# ── gRPC Inter-Service Communication (local development) ────
# Documents Service gRPC (for file upload orchestration)
ORD_DOCUMENTS_GRPC_URL=localhost:50052
ORD_DOCUMENTS_GRPC_TLS_ENABLED=false
ORD_DOCUMENTS_GRPC_CA_CERT_PATH=
ORD_DOCUMENTS_CB_FAIL_THRESHOLD=5
ORD_DOCUMENTS_CB_RECOVERY_TIMEOUT=30

# Payments Service gRPC (for payment status queries)
ORD_PAYMENTS_GRPC_URL=localhost:50051
ORD_PAYMENTS_GRPC_TLS_ENABLED=false
ORD_PAYMENTS_GRPC_CA_CERT_PATH=
