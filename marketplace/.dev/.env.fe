# Market Place FE — local .env
# Connects to the Gravitee API Gateway (or direct FastAPI for dev).
# Copy to market-place-fe/.env and adjust as needed.

# Backend URL — Gravitee Gateway proxying all microservices
# Direct auth-service:  http://localhost:8000
# Via Gravitee Gateway: http://localhost:8082/api/v1
FASTAPI_BASE_URL=http://localhost:8082/api/v1
