# Auth Service — local .env (host-process debugging)
# Connects to Docker infra on localhost ports.
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_REQUEST_BODY=true
SERVICE_PORT=8000

# PostgreSQL
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
AUTH_DB_NAME=auth_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka (host-accessible listener — see local/docker-compose.dev-local.yml)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# JWT keys (repo-local dev keys, never commit real keys)
JWT_PRIVATE_KEY_PATH=./secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt/public.pem

# gRPC
GRPC_PORT=50051
GRPC_REFLECTION_ENABLED=true

# Admin bootstrap
ADMIN_EMAIL=admin@marketplace.sa
ADMIN_PASSWORD=Admin@12345

# SSO — disable Nafath for local dev (use mock/password flow)
SSO_PROVIDER=nafath
NAFATH_BASE_URL=
NAFATH_CLIENT_ID=
NAFATH_CLIENT_SECRET=
