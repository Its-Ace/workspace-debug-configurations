    // ── Frontend — Nuxt dev server (port 3000) ────────────────
    {
      "name": "fe: dev (3000)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder:market-place-fe}",
      "env": {
        "FASTAPI_BASE_URL": "http://localhost:8082/api/v1"
      },
      "console": "internalConsole",
      "skipFiles": ["<node_internals>/**"]
    },

    // ── Infra ─────────────────────────────────────────────────
    {
      "name": "infra: restart",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "make -f .dev/Makefile services-down && make -f .dev/Makefile services-d"],
      "cwd": "${workspaceFolder:market-place-services}",
      "console": "internalConsole",
      "skipFiles": ["<node_internals>/**"]
    }


  ],

  // ── Compound ─────────────────────────────────────────
  "compounds": [
    {
      "name": "🚀 All Services + FE",
      "preLaunchTask": "infra: ensure running",
      "configurations": [
        "auth-service (8000) — reload",
        "application-service (8001) — reload",
        "application-service — taskiq worker",
        "application-service — taskiq scheduler",
        "documents-service (8002) — reload",
        "documents-service — taskiq worker",
        "payments-service (8003) — reload",
        "notifications-service (8004) — reload",
        "fe: dev (3000)"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "all-services",
        "order": 1
      }
    }
  ]
}
