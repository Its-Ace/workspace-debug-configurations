{
  // ── Marketplace — VS Code Debug Configurations ──────────────
  //
  // Prerequisites:
  //   1. Run: make -f .dev/Makefile setup          (creates .venv, installs all deps)
  //   2. Run: make -f .dev/Makefile infra-d        (starts PG, Redis, Kafka, ES in Docker)
  //   3. Run: make -f .dev/Makefile migrate-all    (runs all migrations against localhost DB)
  //   4. Press F5 or use the Run panel to start a service (or "All Services")
  //
  // Each service uses the same .venv and its own .dev/.env.<service>
  // No --reload flag → breakpoints work correctly in the debugger.
  // ────────────────────────────────────────────────────────────
  "version": "0.2.0",
  "configurations": [

    // ── Auth Service (port 8000, gRPC 50051) ─────────────────
    {
      "name": "auth-service (8000)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder:market-place-services}/services/auth-service",
      "python": "${workspaceFolder:market-place-services}/.venv/bin/python",
      "envFile": "${workspaceFolder:market-place-services}/.dev/.env.auth",
      "env": {
        "PYTHONPATH": "${workspaceFolder:market-place-services}/services/auth-service",
        "JWT_PRIVATE_KEY_PATH": "${workspaceFolder:market-place-services}/secrets/jwt/private.pem",
        "JWT_PUBLIC_KEY_PATH": "${workspaceFolder:market-place-services}/secrets/jwt/public.pem"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "internalConsole"
    },

    // ── Auth Service with reload (live-edit, no breakpoints) ──
    {
      "name": "auth-service (8000) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder:market-place-services}/services/auth-service",
      "python": "${workspaceFolder:market-place-services}/.venv/bin/python",
      "envFile": "${workspaceFolder:market-place-services}/.dev/.env.auth",
      "env": {
        "PYTHONPATH": "${workspaceFolder:market-place-services}/services/auth-service",
        "JWT_PRIVATE_KEY_PATH": "${workspaceFolder:market-place-services}/secrets/jwt/private.pem",
        "JWT_PUBLIC_KEY_PATH": "${workspaceFolder:market-place-services}/secrets/jwt/public.pem"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "internalConsole"
    },

