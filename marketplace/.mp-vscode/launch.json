{
  // ── Marketplace — VS Code Debug Configurations ──────────────
  //
  // Prerequisites:
  //   1. Run: make local-setup          (creates .venv, installs all deps)
  //   2. Run: make local-infra-d        (starts PG, Redis, Kafka, ES in Docker)
  //   3. Run: make local-migrate-all    (runs all migrations against localhost DB)
  //   4. Press F5 or use the Run panel to start a service (or "All Services")
  //
  // Each service uses the same .venv and its own services/{name}/.env.local
  // No --reload flag → breakpoints work correctly in the debugger.
  // ────────────────────────────────────────────────────────────
  "version": "0.2.0",
  "configurations": [

    // ── Auth Service (port 8000, gRPC 50051) ─────────────────
    {
      "name": "auth-service (8000)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}/services/auth-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.auth",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/auth-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Auth Service with reload (live-edit, no breakpoints) ──
    {
      "name": "auth-service (8000) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/services/auth-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.auth",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/auth-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Application Service (port 8001) ──────────────────────
    {
      "name": "application-service (8001)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8001"
      ],
      "cwd": "${workspaceFolder}/services/application-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.application",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/application-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Application Service with reload ───────────────────────
    {
      "name": "application-service (8001) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8001",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/services/application-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.application",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/application-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Application Service — Taskiq Worker ───────────────────
    {
      "name": "application-service — taskiq worker",
      "type": "debugpy",
      "request": "launch",
      "module": "taskiq",
      "args": [
        "worker",
        "app.core.taskiq:broker"
      ],
      "cwd": "${workspaceFolder}/services/application-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.application",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/application-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Application Service — Taskiq Scheduler ────────────────
    {
      "name": "application-service — taskiq scheduler",
      "type": "debugpy",
      "request": "launch",
      "module": "taskiq",
      "args": [
        "scheduler",
        "app.core.schedules:scheduler",
        "--skip-first-run"
      ],
      "cwd": "${workspaceFolder}/services/application-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.application",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/application-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Documents Service (port 8002) ─────────────────────────
    {
      "name": "documents-service (8002)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8002"
      ],
      "cwd": "${workspaceFolder}/services/documents-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.documents",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/documents-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Documents Service with reload ─────────────────────────
    {
      "name": "documents-service (8002) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8002",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/services/documents-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.documents",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/documents-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Payments Service (port 8003) ──────────────────────────
    {
      "name": "payments-service (8003)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8003"
      ],
      "cwd": "${workspaceFolder}/services/payments-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.payments",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/payments-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Payments Service with reload ──────────────────────────
    {
      "name": "payments-service (8003) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8003",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/services/payments-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.payments",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/payments-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Notifications Service (port 8004) ─────────────────────
    {
      "name": "notifications-service (8004)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8004"
      ],
      "cwd": "${workspaceFolder}/services/notifications-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.notifications",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/notifications-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Notifications Service with reload ─────────────────────
    {
      "name": "notifications-service (8004) — reload",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8004",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/services/notifications-service",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.dev/.env.notifications",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/services/notifications-service"
      },
      "preLaunchTask": "infra: ensure running",
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Frontend — Nuxt dev server (port 3000) ────────────────
    {
      "name": "fe: dev (3000)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder:market-place-fe}",
      "env": {
        "FASTAPI_BASE_URL": "http://localhost:8082/api/v1"
      }
    },

    // ── Infra ─────────────────────────────────────────────────
    {
      "name": "infra: restart",
      "type": "node-terminal",
      "request": "launch",
      "command": "make -f .dev/Makefile services-down && make -f .dev/Makefile services-d",
      "cwd": "${workspaceFolder}"
    }


  ],

  // ── Compound ─────────────────────────────────────────
  "compounds": [
    {
      "name": "All Services (Debug, Worker, Reload) + FE",
      "preLaunchTask": "infra: ensure running",
      "configurations": [
        "auth-service (8000) — reload",
        "application-service (8001) — reload",
        "application-service — taskiq worker",
        "application-service — taskiq scheduler",
        "documents-service (8002) — reload",
        "payments-service (8003) — reload",
        "notifications-service (8004) — reload",
        "fe: dev (3000)"
      ],
      "stopAll": true
    }
  ]
}
